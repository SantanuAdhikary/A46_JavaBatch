class BinaryToDecimal 
{
	public static int convertDecimal(int n)
	{	
		int sum = 0 ;
		int base = 1;
		while(n > 0)
		{
			int ld = n % 10 ; 
			sum = sum + ld * base ;
			n = n / 10;
			
			base = base * 2;
		}	
		return sum ;
	}
	
	public static void main(String[] args) 
	{
		int binary = 10000;
		int decimal = convertDecimal(binary);
		System.out.println(decimal);
	}
}
