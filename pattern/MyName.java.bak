class MyName 
{
	
	//  SANTANU
	public static void main(String[] args) 
	{
		int n = 7 ;
		
		for(int i=0 ; i<n;i++)
		{
			
			// s 
			
			for(int j=0 ; j<n ;j++)
			{
				if(i==0 || j==0 && i<=n/2 || i==n/2 || i==n-1 || j==n-1 && i>=n/2)
					System.out.print("s ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// A
			
			for(int j=0 ; j<n ;j++)
			{
				if(i==0 || i==n/2 || j==0 || j==n-1)
					System.out.print("a ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// n
			
			for(int j=0 ; j<n ;j++)
			{
				if(j==0 || j==n-1 || i==j)
					System.out.print("n ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// T 
			
			for(int j=0 ; j<n ;j++)
			{
				if(i==0 || j==n/2)
					System.out.print("t ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// A
			
			for(int j=0 ; j<n ;j++)
			{
				if(i==0 || i==n/2 || j==0 || j==n-1)
					System.out.print("a ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// n
			
			for(int j=0 ; j<n ;j++)
			{
				if(j==0 || j==n-1 || i==j)
					System.out.print("n ");
				else
					System.out.print("  ");
			}
			
			System.out.print("  ");
			
			// U
			
			for(int j=0 ; j<n ;j++)
			{
				if(j==0 || j==n-1 || i==n-1)
					System.out.print("u ");
				else
					System.out.print("  ");
			}
			
			
			System.out.println();
			
		}
	}
}
