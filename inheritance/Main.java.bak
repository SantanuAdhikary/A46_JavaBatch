class Parent
{
	int money ; 
	String bike ; 
	
	Parent(int money, String bike)
	{
		this.money = money;
		this.bike = bike;
		System.out.println("i am parent");
	}
}

class Child extends Parent
{
	String phone ; 
	Child()
	{
		super(10000,"royal enfield");
		System.out.println("i am child");
	}
}

class  Main
{
	public static void main(String[] args) 
	{
		
		//Parent p1 = new Parent();
